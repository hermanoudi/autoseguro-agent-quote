# Copie para .env e preencha com valores reais. .env nunca deve ser commitado.

# Chave de API do provedor de LLM (OpenAI). Obrigatoria para o agente rodar.
OPENAI_API_KEY=

# Modelo usado pelo agente. gpt-4o-mini por padrao (custo baixo, function calling
# funciona bem). Troque aqui se preferir outro modelo com suporte a tool calling.
OPENAI_MODEL=gpt-4o-mini

# URL base do quote-service. Default assume execucao via docker compose
# (nome do servico "quote-api"). Para rodar o agent-service fora do compose,
# use http://localhost:8000.
QUOTE_SERVICE_URL=http://quote-api:8000

# Salt usado na pseudonimizacao estavel de identificadores de lead nos logs.
# Gere um valor proprio antes de rodar em qualquer ambiente compartilhado.
PII_HASH_SALT=troque-este-valor
